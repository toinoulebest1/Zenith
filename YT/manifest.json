{
  "name": "ytmusic-spotiflac",
  "displayName": "YouTube Music",
  "version": "2.3.8",
  "description": "YouTube Music metadata & download provider for SpotiFLAC Mobile. Search tracks, albums, playlists on YouTube Music.",
  "type": [
    "metadata_provider",
    "download_provider"
  ],
  "icon": "icon.jpg",
  "minAppVersion": "4.5.1",
  "permissions": {
    "network": [
      "music.youtube.com",
      "*.youtube.com",
      "www.youtube.com",
      "i.ytimg.com",
      "*.googlevideo.com",
      "*.pictube.app",
      "api.zarz.moe",
      "127.0.0.1",
      "localhost",
      "api.song.link",
      "odesli.io",
      "api.deezer.com",
      "yt1d.io"
    ],
    "allowHttp": true,
    "storage": true,
    "file": true
  },
  "qualityOptions": [
    {
      "id": "best",
      "label": "Best Audio",
      "description": "Opus/M4A audio direct from YouTube"
    }
  ],
  "capabilities": {
    "homeFeed": true,
    "downloadFallbackTier": "low_res",
    "shareUrlTemplates": {
      "album": "https://music.youtube.com/browse/{id}",
      "artist": "https://music.youtube.com/browse/{id}"
    }
  },
  "searchBehavior": {
    "enabled": true,
    "placeholder": "Search YouTube Music...",
    "thumbnailRatio": "square",
    "filters": [
      {
        "id": "tracks",
        "label": "Songs",
        "icon": "music"
      },
      {
        "id": "albums",
        "label": "Albums",
        "icon": "album"
      },
      {
        "id": "artists",
        "label": "Artists",
        "icon": "artist"
      },
      {
        "id": "playlists",
        "label": "Playlists",
        "icon": "playlist"
      }
    ]
  },
  "urlHandler": {
    "enabled": true,
    "patterns": [
      "music.youtube.com",
      "youtu.be",
      "www.youtube.com/watch",
      "music.youtube.com/playlist",
      "music.youtube.com/browse"
    ]
  },
  "settings": [
    {
      "key": "poTokenMode",
      "label": "PO Token Mode",
      "type": "select",
      "default": "off",
      "options": [
        "off",
        "auto",
        "external",
        "manual"
      ],
      "description": "Optional GVS PO Token support. Keep off unless direct YouTube downloads start returning 403."
    },
    {
      "key": "poTokenProviderUrl",
      "label": "PO Token Provider URL",
      "type": "string",
      "default": "",
      "description": "Optional BgUtils-compatible provider base URL or /get_pot endpoint. Used for fresh GVS PO tokens when direct YouTube downloads need them."
    },
    {
      "key": "manualGvsPoToken",
      "label": "Manual GVS PO Token",
      "type": "string",
      "default": "",
      "secret": true,
      "description": "Optional raw token or CLIENT.gvs+TOKEN. Manual tokens may expire or be video-bound."
    },
    {
      "key": "logLevel",
      "label": "Log Level",
      "type": "select",
      "default": "warn",
      "options": [
        "error",
        "warn",
        "info",
        "debug"
      ],
      "description": "Controls extension logging verbosity. Use debug only while diagnosing YouTube Music issues."
    }
  ]
}
